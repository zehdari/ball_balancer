<?xml version="1.0" encoding="utf-8"?>
<!--
  Isaac-Sim-friendly URDF rebuilt from the NEW SolidWorks export, but with the OLD “merged” behavior:
  - Adds a world link and fixes the robot base to world
  - Keeps the table as a separate link (child of base)
  - Replaces Ball_1/2/3 mesh links with massless “ball frame” links at the same joint frames (no mesh)
  - Makes magnet *reference frame* links as children of the table, and hangs the magnet meshes off those frames
  - Adds Isaac Sim <loop_joint> spherical constraints: (ball frame) <-> (magnet frame)
-->

<robot name="ball_balancer_system">

  <!-- World link -->
  <link name="world"/>

  <!-- =======================
       ROBOT (from new export)
       ======================= -->

  <link name="base_link">
    <inertial>
      <origin xyz="-8.53269468997393E-05 -0.00541038171468997 0.0257753456010168" rpy="0 0 0" />
      <mass value="0.330312516893083" />
      <inertia
        ixx="0.000550970671660998" ixy="2.50150816127138E-06" ixz="-8.07559804129496E-07"
        iyy="0.0005529500250387"   iyz="6.90294258833593E-07"
        izz="0.00108582378078189" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://ball_balancer/meshes/base_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://ball_balancer/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <!-- Fix robot base to world -->
  <joint name="world_to_base_link" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <!-- Servo arm 1 -->
  <link name="Servo_arm_1">
    <inertial>
      <origin xyz="0.000788143290747698 0.0108393743852739 -4.16333634234434E-16" rpy="0 0 0" />
      <mass value="0.00867785481542915" />
      <inertia
        ixx="1.91158601635292E-06" ixy="-8.11064018692988E-09" ixz="4.55009362279128E-22"
        iyy="2.277418775442E-07"   iyz="6.81030481805436E-20"
        izz="1.81279581350402E-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://ball_balancer/meshes/Servo_arm_1.STL" />
      </geometry>
      <material name="">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://ball_balancer/meshes/Servo_arm_1.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="Servo_arm_1_revolute" type="revolute">
    <origin xyz="0.063196 -0.0049738 0.07505" rpy="0 0 1.5708" />
    <parent link="base_link" />
    <child link="Servo_arm_1" />
    <axis xyz="-1 0 0" />
    <limit lower="0" upper="0" effort="0" velocity="0" />
  </joint>

  <link name="Table_arm_1">
    <inertial>
      <origin xyz="1.99440131783951E-08 -0.0235434815413484 7.79852053767183E-09" rpy="0 0 0" />
      <mass value="0.003906747783009" />
      <inertia
        ixx="4.84797263521725E-07" ixy="1.28297530598978E-12" ixz="4.3644567934529E-15"
        iyy="4.99585473986316E-08" iyz="5.41102266342963E-13"
