      <geometry>
        <mesh filename="package://ball_balancer/meshes/Table.STL" />
      </geometry>
    </collision>
  </link>

  <!-- Keep table as its own link (and prevent collapsing) -->
  <joint name="Table_joint" type="fixed" dont_collapse="true">
    <origin xyz="-0.00047047 -0.0049738 0.10505" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="Table" />
  </joint>


  <!-- =======================
       MAGNETS: frame links (children of table) + meshes hanging off them
       ======================= -->

  <!-- Magnet 1 reference frame (child of table) -->
  <link name="table_magnet_1_link" />
  <joint name="table_magnet_1_joint" type="fixed" dont_collapse="true">
    <origin xyz="0.074036 0 -0.0095" rpy="0 0 0" />
    <parent link="Table" />
    <child link="table_magnet_1_link" />
  </joint>

