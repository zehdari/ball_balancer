  <!-- =======================
       TABLE (from new export)
       ======================= -->

  <link name="Table">
    <inertial>
      <origin xyz="3.14728472654048E-10 7.69662304886694E-11 -0.0025047310879116" rpy="0 0 0" />
      <mass value="0.113623772682042" />
      <inertia
        ixx="0.000203322360548276" ixy="1.84626501287385E-13" ixz="4.51554827674676E-14"
        iyy="0.000203322360267381" iyz="1.03152611607545E-14"
        izz="0.000406174294690233" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://ball_balancer/meshes/Table.STL" />
      </geometry>
