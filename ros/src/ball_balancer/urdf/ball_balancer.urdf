  <!-- Ball 2: frame-only link -->
  <link name="Table_arm_2_ball" />
  <joint name="Table_arm_2_ball_joint" type="fixed" dont_collapse="true">
    <origin xyz="0 -0.053793 0" rpy="0 0 0" />
